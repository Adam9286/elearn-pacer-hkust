{
  "mcpServers": {
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=oqgotlmztpvchkipslnc&features=database%2Cdebugging%2Cdevelopment%2Cfunctions%2Cbranching%2Cdocs%2Caccount%2Cstorage"
    },
    "n8n-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "n8n-mcp"
      ],
      "env": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true",
        "N8N_API_URL": "${env:N8N_API_URL}",
        "N8N_API_KEY": "${env:N8N_API_KEY}",
        "WEBHOOK_SECURITY_MODE": "${env:N8N_WEBHOOK_SECURITY_MODE}"
      }
    }
  }
}
