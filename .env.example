# ==========================================
# BACKEND 1: APPLICATION ENGINE (User Data)
# Supabase project for: Auth, Chat History, Progress
# ==========================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional alias for generated clients that expect a publishable key.
# In Supabase browser apps this is typically the same anon key.
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# ==========================================
# BACKEND 2: KNOWLEDGE BASE (RAG & EXAMS)
# Supabase project for: Lecture Slides, Textbook, Mock Exams
# ==========================================
VITE_KNOWLEDGE_BASE_URL=https://your-kb-project.supabase.co
VITE_KNOWLEDGE_BASE_ANON_KEY=your-kb-anon-key

# ==========================================
# N8N BASE URL
# ==========================================
# For local Docker dev, leave commented out (defaults to http://localhost:5678)
# For remote access via Cloudflare Tunnel:
#   VITE_N8N_BASE_URL=https://your-tunnel.trycloudflare.com
# For VPS / hosted deployment:
#   VITE_N8N_BASE_URL=https://n8n.learningpacer.org
#
# Production builds should set the full webhook URLs explicitly.
# For local dev, you can leave these commented out and the app will fall back
# to localhost webhook-test endpoints.
# VITE_CHAT_RESEARCH_WEBHOOK_URL=https://n8n.learningpacer.org/webhook/your-chat-workflow
# VITE_EXAM_GENERATOR_WEBHOOK_URL=https://n8n.learningpacer.org/webhook/your-exam-workflow

# ==========================================
# APP SETTINGS
# ==========================================
VITE_APP_ENV=development
VITE_TIMEOUT_AGENT=120000

# ==========================================
# SUPABASE EDGE FUNCTION SECRETS
# Set these in Supabase secrets; do not expose them with a VITE_ prefix.
# ==========================================
GEMINI_API_KEY=your-gemini-api-key
# Supabase edge function used by exam generation must point at a production webhook.
# Example:
# N8N_EXAM_GENERATOR_URL=https://n8n.learningpacer.org/webhook/your-exam-workflow
