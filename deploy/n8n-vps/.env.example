# Public domain for the n8n editor and webhook URLs.
N8N_HOST=n8n.example.com

# Email used by Caddy for Let's Encrypt certificate notices.
LETSENCRYPT_EMAIL=ops@example.com

# Image tags.
# `stable` follows n8n's production channel. Replace with an exact version
# after your first successful rollout if you want fully deterministic upgrades.
N8N_IMAGE_TAG=stable
CADDY_IMAGE_TAG=2-alpine
POSTGRES_IMAGE_TAG=16-alpine

# Timezone settings for cron-based workflows and logs.
TZ=Asia/Hong_Kong
GENERIC_TIMEZONE=Asia/Hong_Kong

# Restrict browser-origin requests to your real frontend domain.
N8N_CORS_ORIGIN=https://learningpacer.org

# Generate long random secrets before first deploy.
N8N_ENCRYPTION_KEY=replace_with_a_32_plus_character_random_string
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace_with_a_long_random_password

# Execution retention controls.
EXECUTIONS_DATA_MAX_AGE=336
EXECUTIONS_DATA_PRUNE_MAX_COUNT=10000
