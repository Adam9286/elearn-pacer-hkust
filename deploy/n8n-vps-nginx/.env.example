# Public subdomain that users and webhooks will use.
# Example: n8n.learningpacer.org
N8N_HOST=n8n.example.com

# Keep n8n private behind nginx on the same VPS.
# Leave these as-is unless you have a strong reason to change them.
N8N_BIND_IP=127.0.0.1
N8N_BIND_PORT=5678

# Container image tag.
# `stable` is fine for a 1-month test. For production, pin an exact version.
N8N_IMAGE_TAG=stable

# Browser origin allowed to call n8n directly.
# Set this to your real frontend URL. If you have multiple origins later,
# revisit this and use a tighter long-term policy.
N8N_CORS_ORIGIN=https://learningpacer.org

# Timezone used by cron workflows and timestamps.
TZ=Asia/Hong_Kong
GENERIC_TIMEZONE=Asia/Hong_Kong

# IMPORTANT:
# - Fresh test instance: generate a new long random key.
# - Migrating an existing instance with saved credentials: reuse the current key.
# - Never rotate this casually after migration or stored credentials may break.
N8N_ENCRYPTION_KEY=replace_with_a_long_random_secret

# Execution retention for a short testing deployment.
# Age is in hours.
EXECUTIONS_DATA_MAX_AGE=168
EXECUTIONS_DATA_PRUNE_MAX_COUNT=5000
